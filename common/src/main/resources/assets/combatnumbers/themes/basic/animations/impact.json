[
  {
    "start": 0,
    "duration": 0,
    "channels": {
      "x": { "type": "random", "min": -8, "max": 8 },
      "y": { "type": "random", "min": 8, "max": 16 }
    }
  },
  {
    "start": 0,
    "duration": 200,
    "label": "enter",
    "channels": {
      "scale": { "type": "keyframe", "values": [1.8, 0.8], "easing": "ease_out" },
      "opacity": { "type": "keyframe", "values": [0, 1], "easing": "ease_out" }
    }
  },
  {
    "start": 0,
    "duration": 600,
    "channels": {
      "y": { "type": "tween", "to": 8, "compose": "add", "easing": "linear" }
    }
  },
  {
    "start": 600,
    "duration": 300,
    "label": "exit",
    "channels": {
      "opacity": { "type": "keyframe", "values": [1, 0], "easing": "ease_out_circ" },
      "y": { "type": "tween", "to": 6, "compose": "add", "easing": "ease_out_circ" }
    }
  }
