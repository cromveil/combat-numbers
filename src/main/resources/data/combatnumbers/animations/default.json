[
  {
    "start": 0,
    "duration": 200,
    "label": "enter",
    "channels": {
      "scale": { "type": "keyframe", "values": [1.5, 1], "easing": "ease_out" },
      "opacity": { "type": "keyframe", "values": [0, 1], "easing": "ease_out" }
    }
  },
  {
    "start": 50,
    "duration": 450,
    "label": "hold",
    "channels": {
      "y": {
        "type": "keyframe",
        "times": [0, 0.25, 0.5, 0.75, 1],
        "values": [0, 0.2, 0, 0.1, 0],
        "easing": ["ease_out_circ", "ease_in_circ", "ease_out_circ", "ease_in_circ"]
      }
    }
  },
  {
    "start": 50,
    "duration": 700,
    "channels": {
      "y": { "type": "tween", "to": { "type": "random", "min": -0.1, "max": 0.4 }, "compose": "add", "easing": "ease_out" },
      "x": { "type": "tween", "to": { "type": "random", "min": 0.25, "max": 0.5, "signed": true }, "compose": "add", "easing": "ease_out" },
      "z": { "type": "tween", "to": { "type": "random", "min": 0.25, "max": 0.5, "signed": true }, "compose": "add", "easing": "ease_out" }
    }
  },
  {
    "start": 800,
    "duration": 300,
    "label": "exit",
    "channels": {
      "scale": { "type": "keyframe", "values": [1, 0.9], "easing": "ease_out_circ" },
      "opacity": { "type": "keyframe", "values": [1, 0], "easing": "ease_out_circ" },
      "y": { "type": "tween", "to": 0.2, "compose": "add", "easing": "ease_out_circ" }
